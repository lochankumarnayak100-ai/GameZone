# ══════════════════════════════════════════════════════
#  GameZone — Environment Variables
#  Copy this file to .env and fill in your values
#  NEVER commit .env to Git — add it to .gitignore
# ══════════════════════════════════════════════════════

# ── Razorpay Keys ──────────────────────────────────────
# Get from: https://dashboard.razorpay.com → Settings → API Keys
# Use rzp_test_ keys for testing, rzp_live_ for production

RAZORPAY_KEY_ID=rzp_test_REPLACE_WITH_YOUR_KEY_ID
RAZORPAY_KEY_SECRET=REPLACE_WITH_YOUR_KEY_SECRET

# ── Webhook Secret ─────────────────────────────────────
# Set in: Razorpay Dashboard → Settings → Webhooks → Add New Webhook
# Enter any strong random string here and the same in Razorpay dashboard

RAZORPAY_WEBHOOK_SECRET=REPLACE_WITH_YOUR_WEBHOOK_SECRET

# ── Server Config ──────────────────────────────────────
PORT=3000

# ── Frontend URL (for CORS) ────────────────────────────
# Local development:
FRONTEND_URL=http://localhost:5500
# Production (replace with your actual domain):
# FRONTEND_URL=https://yourdomain.com
